# Docker/Postgres
POSTGRES_DB=github_human_auth
POSTGRES_USER=github_human_auth
POSTGRES_PASSWORD=github_human_auth
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info
DATABASE_URL=postgres://github_human_auth:github_human_auth@localhost:5432/github_human_auth
CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_SECURE=false
SESSION_COOKIE_NAME=gho_session

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000

# GitHub App / OAuth values are required before Phase 1 runtime use.
GITHUB_APP_ID=
# Paste the PEM contents for Docker/API runtime, or map it in your deployment and set the app env accordingly.
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_API_BASE=https://api.github.com
GITHUB_WEB_URL=http://localhost:3000

# CAPTCHA provider credentials are required before verification flows are enabled.
TURNSTILE_SECRET=
TURNSTILE_DEV_BYPASS=false
