# Docker/Postgres
POSTGRES_DB=github_human_auth
POSTGRES_USER=github_human_auth
# Use a strong unique password in any non-local deployment (openssl rand -hex 24).
# docker-compose binds Postgres to 127.0.0.1 only; never publish it externally.
POSTGRES_PASSWORD=github_human_auth
POSTGRES_PORT=5432

# API
API_HOST=0.0.0.0
API_PORT=8080
RUST_LOG=info
DATABASE_URL=postgres://github_human_auth:github_human_auth@localhost:5432/github_human_auth
CORS_ALLOWED_ORIGINS=http://localhost:3000
# false is for plain-HTTP local development only; production (the docker-compose
# default) must keep this true so session cookies are HTTPS-only.
COOKIE_SECURE=false
SESSION_COOKIE_NAME=gho_session
# Optional legacy machine token for policy/admin API routes.
# Use at least 32 random characters in production.
ADMIN_API_TOKEN=
# Comma-separated GitHub logins allowed to use the web dashboard.
# REQUIRED (at least one login) whenever GITHUB_OAUTH_CLIENT_ID/SECRET are set; an empty list authorizes nobody.
ADMIN_GITHUB_LOGINS=
# Signing secret for browser dashboard sessions (>=32 chars).
# REQUIRED whenever GITHUB_OAUTH_CLIENT_ID/SECRET are set; there is no fallback to the OAuth client secret.
ADMIN_SESSION_SECRET=
ADMIN_SESSION_COOKIE_NAME=gho_admin_session
# Base64-encoded 32-byte key used to encrypt dashboard-managed CAPTCHA secrets at rest.
# Required to save provider secrets via the dashboard. Generate with: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:3000

# GitHub App / OAuth values are required before Phase 1 runtime use.
GITHUB_APP_ID=
# Paste the PEM contents for Docker/API runtime, or map it in your deployment and set the app env accordingly.
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_API_BASE=https://api.github.com
GITHUB_WEB_URL=http://localhost:3000

# CAPTCHA provider credentials are required before verification flows are enabled.
TURNSTILE_SECRET=
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
RECAPTCHA_SECRET=
RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
TURNSTILE_DEV_BYPASS=false
# Set true only when API is reachable exclusively through trusted reverse proxies that set cf-connecting-ip/x-forwarded-for.
TRUST_PROXY_HEADERS=false
